generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Multi-tenant root ───────────────────────────────────────────────────────

model Company {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  plan           String   @default("starter")
  webhookApiKey  String?  @unique
  logoUrl        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users            User[]
  events           Event[]
  travelRequests   TravelRequest[]
  expenses         Expense[]
  auditLogs        AuditLog[]
  payoutReports    PayoutReport[]
  cardTransactions CardTransaction[]
  policyRules      PolicyRule[]
  travelerProfiles    TravelerProfile[]
  travelInboxMessages TravelInboxMessage[]
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

enum Role {
  EMPLOYEE
  MANAGER
  TRAVEL_MANAGER
  TRAVEL_AGENT
  FINANCE_ADMIN
  SYSTEM_ADMIN
}

enum TokenType {
  INVITE
  PASSWORD_RESET
}

model User {
  id            String    @id @default(cuid())
  companyId     String
  email         String
  name          String
  role          Role      @default(EMPLOYEE)
  passwordHash  String?
  mfaSecret     String?
  mfaEnabled    Boolean   @default(false)
  managerId     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  manager              User?                 @relation("ManagerReports", fields: [managerId], references: [id])
  directReports        User[]                @relation("ManagerReports")
  travelRequests       TravelRequest[]       @relation("EmployeeTravelRequests")
  agentBookings        TravelRequest[]       @relation("AgentBookings")
  managedRequests      TravelRequest[]       @relation("ManagerTravelRequests")
  expenses             Expense[]
  approvalActions      ApprovalAction[]
  auditLogs            AuditLog[]
  delegationsGiven     Delegation[]          @relation("DelegatorDelegations")
  delegationsReceived  Delegation[]          @relation("DelegateDelegations")
  travelerProfile      TravelerProfile?
  verificationTokens   VerificationToken[]
  eventDocuments       EventDocument[]
  assignedInboxMessages TravelInboxMessage[] @relation("InboxAssignee")
  notifications        Notification[]

  @@unique([companyId, email])
}

model Notification {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  type        String
  title       String
  description String
  href        String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model VerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  type      TokenType
  expiresAt DateTime
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Delegation {
  id          String   @id @default(cuid())
  companyId   String
  delegatorId String
  delegateId  String
  startDate   DateTime
  endDate     DateTime
  createdAt   DateTime @default(now())

  delegator User @relation("DelegatorDelegations", fields: [delegatorId], references: [id])
  delegate  User @relation("DelegateDelegations", fields: [delegateId], references: [id])
}

// ─── Events (cost center tagging) ────────────────────────────────────────────

enum EventStatus {
  DRAFT
  ACTIVE
  CLOSED
}

model Event {
  id               String      @id @default(cuid())
  companyId        String
  eventCode        String
  eventName        String
  status           EventStatus @default(DRAFT)
  ownerUserId      String

  // Event details
  venue            String?
  address          String?
  eventDate        DateTime?
  dateStart        DateTime?
  dateEnd          DateTime?
  timing           String?

  // Staff
  assignedDj       String?
  assignedMc       String?
  salesPerson      String?
  service          String?

  // Finance (kept for budget tracking)
  costCenter       String?
  budgetUsd        Decimal     @default(0) @db.Decimal(12, 2)
  approvedSpendUsd Decimal     @default(0) @db.Decimal(12, 2)

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  company        Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  travelRequests TravelRequest[]
  expenses       Expense[]
  documents      EventDocument[]

  @@unique([companyId, eventCode])
}

model EventDocument {
  id         String   @id @default(cuid())
  eventId    String
  uploadedBy String
  fileName   String
  mimeType   String
  fileData   Bytes
  uploadedAt DateTime @default(now())

  event    Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploader User  @relation(fields: [uploadedBy], references: [id])
}

// ─── Travel Requests ─────────────────────────────────────────────────────────

enum TravelRequestStatus {
  DRAFT
  SUBMITTED
  PENDING_AGENT
  PENDING_MANAGER
  PENDING_ADMIN
  OPTIONS_PROVIDED
  APPROVED
  BOOKING_CONFIRMED
  REJECTED
  CANCELLED
}

enum RoutingPath {
  AGENT_FIRST
  MANAGER_FIRST
  PARALLEL
  MANAGER_ONLY
}

enum TravelClass {
  ECONOMY
  BUSINESS
  FIRST
}

model TravelRequest {
  id                String              @id @default(cuid())
  companyId         String
  employeeId        String
  agentId           String?
  eventId           String
  origin            String
  destination       String
  travelDates       Json
  servicesRequested String[]
  approvedServices  String[]            @default([])
  rejectedServices  String[]            @default([])
  managerId         String?
  estimatedCostUsd  Decimal?            @db.Decimal(12, 2)
  purpose           String
  preferredClass    TravelClass         @default(ECONOMY)
  hotelNights       Int?
  carRentalDays     Int?
  specialInstructions String?
  confirmationNumber  String?
  confirmationDocUrl  String?
  status            TravelRequestStatus @default(DRAFT)
  routingPath       RoutingPath         @default(AGENT_FIRST)
  rejectionNote     String?
  adminEscalationNote String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee              User                  @relation("EmployeeTravelRequests", fields: [employeeId], references: [id])
  agent                 User?                 @relation("AgentBookings", fields: [agentId], references: [id])
  manager               User?                 @relation("ManagerTravelRequests", fields: [managerId], references: [id])
  event                 Event                 @relation(fields: [eventId], references: [id])
  approvalActions       ApprovalAction[]
  expenses              Expense[]
  bookingOptions        BookingOption[]
  bookingConfirmations  BookingConfirmation[]
}

// ─── Booking Confirmations (per-service) ─────────────────────────────────────

model BookingConfirmation {
  id                 String        @id @default(cuid())
  travelRequestId    String
  serviceType        String
  confirmationNumber String?
  notes              String?
  fileName           String?
  fileData           Bytes?
  mimeType           String?
  createdAt          DateTime      @default(now())

  travelRequest TravelRequest @relation(fields: [travelRequestId], references: [id], onDelete: Cascade)
}

// ─── Booking Options (Travel Agent) ──────────────────────────────────────────

model BookingOption {
  id              String   @id @default(cuid())
  travelRequestId String
  serviceType     String
  vendor          String
  description     String
  priceUsd        Decimal  @db.Decimal(12, 2)
  bookingLink     String?
  isSelected      Boolean  @default(false)
  createdAt       DateTime @default(now())

  travelRequest TravelRequest @relation(fields: [travelRequestId], references: [id], onDelete: Cascade)
}

// ─── Expenses ─────────────────────────────────────────────────────────────────

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  PAID
}

enum ExpenseCategory {
  MEALS
  TRANSPORT
  ACCOMMODATION
  SUPPLIES
  OTHER
}

enum ExpenseType {
  OUT_OF_POCKET
  CORPORATE_CARD
}

model Expense {
  id              String          @id @default(cuid())
  companyId       String
  employeeId      String
  eventId         String
  travelRequestId String?
  category        ExpenseCategory
  expenseType     ExpenseType     @default(OUT_OF_POCKET)
  amountUsd       Decimal         @db.Decimal(12, 2)
  currency        String          @default("USD")
  description     String
  status          ExpenseStatus   @default(DRAFT)
  merchantName    String?
  transactionDate DateTime?
  service         String?
  reason          String?
  personName      String?
  rejectionNote   String?
  payoutReportId  String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  company        Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employee       User             @relation(fields: [employeeId], references: [id])
  event          Event            @relation(fields: [eventId], references: [id])
  travelRequest  TravelRequest?   @relation(fields: [travelRequestId], references: [id])
  payoutReport   PayoutReport?    @relation(fields: [payoutReportId], references: [id])
  receipts       Receipt[]
  approvalActions ApprovalAction[]
  comments       Comment[]
}

// ─── Receipts ─────────────────────────────────────────────────────────────────

model Receipt {
  id           String   @id @default(cuid())
  expenseId    String
  s3Key        String?
  fileData     Bytes?
  fileName     String
  mimeType     String
  ocrMerchant  String?
  ocrAmount    Decimal? @db.Decimal(12, 2)
  ocrDate      DateTime?
  ocrRaw       Json?
  uploadedAt   DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

// ─── Approval Actions ─────────────────────────────────────────────────────────

enum ApprovalActionType {
  APPROVE
  REJECT
  DELEGATE
  ESCALATE
  MODIFY
  SUBMIT
}

model ApprovalAction {
  id              String             @id @default(cuid())
  companyId       String
  actorId         String
  travelRequestId String?
  expenseId       String?
  actionType      ApprovalActionType
  note            String?
  ipAddress       String?
  createdAt       DateTime           @default(now())

  actor         User           @relation(fields: [actorId], references: [id])
  travelRequest TravelRequest? @relation(fields: [travelRequestId], references: [id])
  expense       Expense?       @relation(fields: [expenseId], references: [id])
}

// ─── Comments ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(cuid())
  expenseId String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  expense Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
}

// ─── Card Transactions ────────────────────────────────────────────────────────

enum CardTransactionStatus {
  PENDING_TAG
  TAGGED
  SUBMITTED
  MATCHED
}

model CardTransaction {
  id             String                @id @default(cuid())
  companyId      String
  employeeId     String?
  transactionId  String                @unique
  merchant       String
  amountUsd      Decimal               @db.Decimal(12, 2)
  currency       String                @default("USD")
  transactionDate DateTime
  mccCode        String?
  cardProgram    String
  eventId        String?
  status         CardTransactionStatus @default(PENDING_TAG)
  createdAt      DateTime              @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  actorId    String?
  action     String
  entityType String
  entityId   String
  payload    Json
  ipAddress  String?
  createdAt  DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  actor   User?   @relation(fields: [actorId], references: [id])
}

// ─── Payout Reports ───────────────────────────────────────────────────────────

enum PayoutReportStatus {
  GENERATED
  FINANCE_REVIEWED
  PAID
  EXPORTED
}

model PayoutReport {
  id          String             @id @default(cuid())
  companyId   String
  periodStart DateTime
  periodEnd   DateTime
  status      PayoutReportStatus @default(GENERATED)
  totalUsd    Decimal            @default(0) @db.Decimal(12, 2)
  generatedAt DateTime           @default(now())
  reviewedAt  DateTime?
  paidAt      DateTime?
  exportedAt  DateTime?

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  expenses Expense[]
}

// ─── Policy Rules ─────────────────────────────────────────────────────────────

enum PolicyRuleType {
  AMOUNT_THRESHOLD
  CATEGORY_POLICY
  MISSING_RECEIPT
  EVENT_BUDGET_CAP
}

model PolicyRule {
  id          String         @id @default(cuid())
  companyId   String
  ruleType    PolicyRuleType
  config      Json
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ─── Travel Inbox ─────────────────────────────────────────────────────────────

enum InboxChannel {
  TRAVEL_CARS
  TRAVEL_FLIGHTS
  TRAVEL_HOTELS
}

enum InboxStatus {
  NEW
  IN_PROGRESS
  DONE
  IGNORED
}

model TravelInboxMessage {
  id              String       @id @default(cuid())
  companyId       String
  channel         InboxChannel
  slackUserId     String?
  slackUserName   String?
  slackMsgTs      String?
  slackThreadTs   String?
  slackChannelId  String?
  rawText         String
  parsedData      Json?
  status          InboxStatus  @default(NEW)
  assignedToId    String?
  travelRequestId String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo User?   @relation("InboxAssignee", fields: [assignedToId], references: [id])
}

// ─── Traveler Profile ─────────────────────────────────────────────────────────

model TravelerProfile {
  id                     String    @id @default(cuid())
  userId                 String    @unique
  companyId              String

  // Travel documents
  dateOfBirth            DateTime?
  passportNumber         String?
  passportIssueDate      DateTime?
  passportExpiry         DateTime?
  passportPhotoKey       String?
  driversLicenseNumber   String?
  driversLicenseIssueDate DateTime?
  driversLicenseExpiry   DateTime?
  driversLicensePhotoKey String?

  // Travel programs
  ktnNumber              String?
  globalEntryNumber      String?

  // Contact information
  firstName              String?
  lastName               String?
  phoneNumber            String?
  contactEmail           String?
  homeAddress            String?

  // Profile photo
  profilePhotoKey        String?

  // Airline loyalty accounts [{airline: string, number: string}]
  airlineAccounts        Json?

  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}
