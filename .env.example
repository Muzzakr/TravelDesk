# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://...
DIRECT_URL=postgresql://...

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# AUTH_SECRET is preferred by middleware; falls back to NEXTAUTH_SECRET
AUTH_SECRET=

# ─── Google OAuth (Sign in with Google) ───────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cron (Vercel scheduled jobs) — REQUIRED, endpoints refuse without it ─────
CRON_SECRET=

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ─── AI (Claude) ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── File Storage (Supabase) ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_BUCKET=

# ─── Outgoing Slack Notifications (existing) ──────────────────────────────────
SLACK_WEBHOOK_URL=

# ─── Travel Inbox — Slack Events API (new) ────────────────────────────────────
# Slack Bot Token (xoxb-...) — needs channels:history, chat:write, users:read
SLACK_BOT_TOKEN=xoxb-...

# Slack App Signing Secret — used to verify event payloads
SLACK_SIGNING_SECRET=

# Channel IDs for the three travel channels (copy from channel settings in Slack)
SLACK_CHANNEL_CARS=C08NMGD65U3
SLACK_CHANNEL_FLIGHTS=C07MM6E7095
SLACK_CHANNEL_HOTELS=C08NN8TN1V0

# The companyId to associate incoming Slack messages with
# (find your companyId in the database or admin panel)
INBOX_COMPANY_ID=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
